<Window x:Class="SafeStorageScanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Safe Storage Scanner" Height="860" Width="1320" MinHeight="720" MinWidth="1120"
        Background="{DynamicResource AppBackground}">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBackground" Color="#F3F6FA"/>
        <SolidColorBrush x:Key="PanelBackground" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SubtlePanelBackground" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextBrush" Color="#111827"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#DCE3EC"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,16,16"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,6,12,6"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="MinHeight" Value="36"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,6,12,6"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="MinHeight" Value="36"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>
        <Style x:Key="PageHostTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <ContentPresenter ContentSource="SelectedContent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ButtonHoverBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="236"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="0,0,1,0" Padding="16">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,22">
                    <TextBlock Text="Safe Storage" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="Storage cleanup assistant" FontSize="13" Foreground="{DynamicResource MutedTextBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button DockPanel.Dock="Bottom" Content="Settings" Click="OpenSettings_Click" Margin="0,16,0,0" Style="{StaticResource SidebarButtonStyle}"/>
                <ListBox x:Name="NavigationList" SelectionChanged="NavigationList_SelectionChanged" BorderThickness="0" Background="Transparent" SelectedIndex="0">
                    <ListBoxItem Content="Dashboard" Padding="12,10"/>
                    <ListBoxItem Content="Scan" Padding="12,10"/>
                    <ListBoxItem Content="Results" Padding="12,10"/>
                    <ListBoxItem Content="Duplicates" Padding="12,10"/>
                    <ListBoxItem Content="Installed Apps" Padding="12,10"/>
                    <ListBoxItem Content="Storage Visualization" Padding="12,10"/>
                    <ListBoxItem Content="AI Analysis" Padding="12,10"/>
                    <ListBoxItem Content="Reports" Padding="12,10"/>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock x:Name="PageTitleTextBlock" Text="Dashboard" FontSize="30" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock x:Name="PageSubtitleTextBlock" Text="Review drive health, quick wins, and recent scan context." FontSize="14" Foreground="{DynamicResource MutedTextBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="ScanButton" Content="Start Scan" Click="StartScan_Click" FontWeight="SemiBold" Background="{DynamicResource AccentBrush}" Foreground="White"/>
                    <Button x:Name="CancelButton" Content="Cancel" Click="Cancel_Click" IsEnabled="False"/>
                </StackPanel>
            </DockPanel>

            <TabControl Grid.Row="1" x:Name="MainTabs" Style="{StaticResource PageHostTabControlStyle}">
                <TabItem>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <UniformGrid Columns="4" Margin="0,0,0,6">
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Recoverable" Foreground="{DynamicResource MutedTextBrush}"/>
                                        <TextBlock x:Name="RecoverableTextBlock" Text="0 B" FontSize="26" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Files scanned" Foreground="{DynamicResource MutedTextBrush}"/>
                                        <TextBlock x:Name="FilesScannedTextBlock" Text="0" FontSize="26" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Duplicate groups" Foreground="{DynamicResource MutedTextBrush}"/>
                                        <TextBlock x:Name="DuplicateGroupsTextBlock" Text="0" FontSize="26" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Installed apps" Foreground="{DynamicResource MutedTextBrush}"/>
                                        <TextBlock x:Name="InstalledAppsCountTextBlock" Text="0" FontSize="26" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Drive Usage" FontSize="18" FontWeight="SemiBold"/>
                                        <DataGrid x:Name="DrivesGrid" Height="240" Margin="0,12,0,0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Drive" Binding="{Binding Name}" Width="70"/>
                                                <DataGridTextColumn Header="Used" Binding="{Binding UsedText}" Width="100"/>
                                                <DataGridTextColumn Header="Free" Binding="{Binding FreeText}" Width="100"/>
                                                <DataGridTextColumn Header="Used %" Binding="{Binding UsedPercent, StringFormat=0.0}" Width="80"/>
                                                <DataGridTextColumn Header="Move target" Binding="{Binding MoveTargetScore}" Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Largest Folders" FontSize="18" FontWeight="SemiBold"/>
                                        <DataGrid x:Name="DashboardFoldersGrid" Height="240" Margin="0,12,0,0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Folder" Binding="{Binding Path}" Width="*"/>
                                                <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="100"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Recent Scan Summary" FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="AiSummaryTextBlock" Text="No scan has run yet." TextWrapping="Wrap" Foreground="{DynamicResource MutedTextBrush}" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="820">
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Choose what to scan" FontSize="20" FontWeight="SemiBold"/>
                                    <TextBlock Text="Start with one drive or folder. Multi-drive and low storage presets are available when needed." Foreground="{DynamicResource MutedTextBrush}" Margin="0,4,0,16"/>
                                    <WrapPanel>
                                        <RadioButton x:Name="SingleDriveRadio" Content="Single drive" IsChecked="True" Margin="0,0,18,0"/>
                                        <RadioButton x:Name="MultiDriveRadio" Content="Multiple drives" Margin="0,0,18,0"/>
                                        <RadioButton x:Name="FolderRadio" Content="Folder" Margin="0,0,18,0"/>
                                    </WrapPanel>
                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="DriveComboBox"/>
                                        <TextBox Grid.Column="1" x:Name="FolderTextBox" IsEnabled="False" ToolTip="Selected folder path"/>
                                        <Button Grid.Column="2" Content="Browse" Click="BrowseFolder_Click"/>
                                    </Grid>
                                    <Border x:Name="MultiDrivePanel" Visibility="Collapsed" Background="{DynamicResource InputBackground}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,12,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Select drives to scan" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                            <WrapPanel x:Name="MultiDriveChoicesPanel"/>
                                        </StackPanel>
                                    </Border>
                                    <Button Content="Start Scan" Click="StartScan_Click" HorizontalAlignment="Left" Margin="0,18,0,0" Background="{DynamicResource AccentBrush}" Foreground="White"/>
                                </StackPanel>
                            </Border>
                            <Expander Header="Advanced scan options" Margin="0,0,16,16">
                                <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                                    <StackPanel>
                                        <WrapPanel>
                                            <CheckBox x:Name="LowStorageModeCheckBox" Content="Low storage mode" Margin="0,0,20,8"/>
                                            <CheckBox x:Name="DuplicateCheckBox" Content="Find duplicates" IsChecked="True" Margin="0,0,20,8"/>
                                            <CheckBox x:Name="VerifyDuplicateCheckBox" Content="Verify duplicate content" Margin="0,0,20,8"/>
                                            <CheckBox x:Name="DryRunCheckBox" Content="Dry-run mode" IsChecked="True" Margin="0,0,20,8"/>
                                            <CheckBox x:Name="PortableModeCheckBox" Content="Portable mode" IsChecked="True" Margin="0,0,20,8"/>
                                        </WrapPanel>
                                        <TextBlock Text="Move instead of delete" FontSize="16" FontWeight="SemiBold" Margin="0,14,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="MoveTargetTextBox" ToolTip="Move target folder"/>
                                            <Button Grid.Column="1" Content="Browse" Click="BrowseMoveTarget_Click"/>
                                            <Button Grid.Column="2" Content="Plan Move for Selection" Click="PlanMove_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource Card}">
                            <WrapPanel>
                                <TextBox x:Name="TypeFilterTextBox" Width="160" ToolTip="Type filter, e.g. .zip"/>
                                <TextBox x:Name="FolderFilterTextBox" Width="240" ToolTip="Folder/path contains"/>
                                <ComboBox x:Name="AgeFilterComboBox" Width="140">
                                    <ComboBoxItem Content="Any date"/>
                                    <ComboBoxItem Content="30 days"/>
                                    <ComboBoxItem Content="90 days" IsSelected="True"/>
                                    <ComboBoxItem Content="180 days"/>
                                    <ComboBoxItem Content="365 days"/>
                                    <ComboBoxItem Content="2 years"/>
                                </ComboBox>
                                <TextBox x:Name="MinSizeTextBox" Width="100" Text="50" ToolTip="Minimum size MB"/>
                                <Button Content="Apply Filters" Click="ApplyFilters_Click"/>
                                <Button Content="Clear" Click="ClearFilters_Click"/>
                            </WrapPanel>
                        </Border>
                        <TabControl Grid.Row="1" Margin="0,0,0,0">
                            <TabItem Visibility="Visible" Header="Quick Wins">
                                <DataGrid x:Name="QuickWinsGrid" SelectionChanged="QuickWinsGrid_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Recoverable" Binding="{Binding EstimatedRecoverableText}" Width="110"/>
                                        <DataGridTextColumn Header="Confidence" Binding="{Binding ConfidenceScore}" Width="85"/>
                                        <DataGridTextColumn Header="Action" Binding="{Binding RecommendedAction}" Width="180"/>
                                        <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="3*"/>
                                        <DataGridTextColumn Header="Evidence" Binding="{Binding Evidence}" Width="2*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Visibility="Visible" Header="Biggest Files">
                                <DataGrid x:Name="FilesGrid" SelectionChanged="FilesGrid_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="3*"/>
                                        <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="90"/>
                                        <DataGridTextColumn Header="Recoverable" Binding="{Binding EstimatedRecoverableText}" Width="105"/>
                                        <DataGridTextColumn Header="Type" Binding="{Binding FileType}" Width="80"/>
                                        <DataGridTextColumn Header="Last Accessed" Binding="{Binding LastAccessed}" Width="140"/>
                                        <DataGridTextColumn Header="Category" Binding="{Binding CategoryText}" Width="130"/>
                                        <DataGridTextColumn Header="Why" Binding="{Binding Explanation}" Width="2*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Visibility="Visible" Header="Biggest Folders">
                                <DataGrid x:Name="FoldersGrid" SelectionChanged="FoldersGrid_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="4*"/>
                                        <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="100"/>
                                        <DataGridTextColumn Header="Category" Binding="{Binding CategoryText}" Width="140"/>
                                        <DataGridTextColumn Header="Why" Binding="{Binding Explanation}" Width="2*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </TabItem>

                <TabItem>
                    <DataGrid x:Name="DuplicatesGrid">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Copies" Binding="{Binding Count}" Width="70"/>
                            <DataGridTextColumn Header="Each Size" Binding="{Binding SizeText}" Width="100"/>
                            <DataGridTextColumn Header="Possible Recovery" Binding="{Binding RecoverableText}" Width="130"/>
                            <DataGridTextColumn Header="Confidence" Binding="{Binding ConfidenceScore}" Width="85"/>
                            <DataGridTextColumn Header="SHA-256" Binding="{Binding Hash}" Width="220"/>
                            <DataGridTextColumn Header="Paths" Binding="{Binding Paths}" Width="4*"/>
                            <DataGridTextColumn Header="Why" Binding="{Binding Explanation}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem>
                    <DockPanel>
                        <Button DockPanel.Dock="Top" Content="Load Installed Apps" Click="LoadInstalledApps_Click" HorizontalAlignment="Left" Margin="0,0,0,16"/>
                        <DataGrid x:Name="AppsGrid">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="App" Binding="{Binding DisplayName}" Width="2*"/>
                                <DataGridTextColumn Header="Size" Binding="{Binding InstallSizeText}" Width="110"/>
                                <DataGridTextColumn Header="Install Location" Binding="{Binding InstallLocation}" Width="2*"/>
                                <DataGridTextColumn Header="Publisher" Binding="{Binding Publisher}" Width="180"/>
                                <DataGridTextColumn Header="Last Used" Binding="{Binding LastUsedText}" Width="170"/>
                                <DataGridTextColumn Header="Action" Binding="{Binding RecommendedAction}" Width="180"/>
                                <DataGridTextColumn Header="Why" Binding="{Binding Explanation}" Width="2*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>

                <TabItem>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="340"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource Card}" Margin="0,0,16,0">
                            <Canvas x:Name="TreemapCanvas" Background="{DynamicResource SubtlePanelBackground}" SizeChanged="TreemapCanvas_SizeChanged"/>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0">
                            <StackPanel>
                                <TextBlock Text="Storage Breakdown" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock Text="Treemap shows largest folders. Bars compare quick-win categories." TextWrapping="Wrap" Foreground="{DynamicResource MutedTextBrush}" Margin="0,6,0,12"/>
                                <ItemsControl x:Name="ChartItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="132"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="90"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Action}" TextTrimming="CharacterEllipsis"/>
                                                <Border Grid.Column="1" Background="#D7DEE8" Height="16" CornerRadius="3">
                                                    <Border Width="{Binding BarWidth}" HorizontalAlignment="Left" Background="#059669" CornerRadius="3"/>
                                                </Border>
                                                <TextBlock Grid.Column="2" Text="{Binding Text}" Margin="8,0,0,0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource Card}">
                            <WrapPanel>
                                <Button Content="Explain Selection" Click="ExplainThis_Click"/>
                                <Button Content="Summarize Scan" Click="SummarizeScan_Click"/>
                                <TextBlock Text="Cloud AI is enabled only when an API key is saved in Settings." VerticalAlignment="Center" Foreground="{DynamicResource MutedTextBrush}"/>
                            </WrapPanel>
                        </Border>
                        <TextBox x:Name="AiOutputTextBox" Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True" FontSize="15"/>
                    </Grid>
                </TabItem>

                <TabItem>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Export Reports" FontSize="20" FontWeight="SemiBold"/>
                                    <TextBlock Text="Create shareable reports from the current scan results." Foreground="{DynamicResource MutedTextBrush}" Margin="0,4,0,16"/>
                                    <WrapPanel>
                                        <Button Content="Export CSV" Click="ExportFilesCsv_Click"/>
                                        <Button Content="Export JSON" Click="ExportFilesJson_Click"/>
                                        <Button Content="Export HTML" Click="ExportHtml_Click"/>
                                        <Button Content="Export PDF" Click="ExportPdf_Click"/>
                                        <Button Content="Export Duplicates JSON" Click="ExportDuplicatesJson_Click"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Scan History and Audit Logs" FontSize="20" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="LogPathTextBlock" Text="No safety log yet" TextWrapping="Wrap" Foreground="{DynamicResource MutedTextBrush}" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <StatusBar Grid.Row="2" Margin="0,18,0,0" Background="Transparent">
                <StatusBarItem>
                    <TextBlock x:Name="StatusTextBlock" Text="Ready"/>
                </StatusBarItem>
                <Separator/>
                <StatusBarItem>
                    <TextBlock x:Name="SummaryTextBlock" Text="No scan has run yet"/>
                </StatusBarItem>
            </StatusBar>
        </Grid>
    </Grid>
</Window>
